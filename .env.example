# ---- Shared infra ----
POSTGRES_USER=dast
POSTGRES_PASSWORD=dast
POSTGRES_DB=dast
DATABASE_URL=postgresql://dast:dast@postgres:5432/dast?schema=public

REDIS_URL=redis://redis:6379

# ---- Backend API / worker ----
API_PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# OWASP ZAP daemon (used by the ZAP engine adapter, full profile only)
ZAP_BASE_URL=http://zap:8080
ZAP_API_KEY=change-me
# Overall time budget (ms) for ZAP passive drain + active scan.
ZAP_TIMEOUT_MS=300000

# Safety: scans refuse to run against hosts not on a target's scope allow-list.
# SAFE_MODE excludes destructive/active-write payloads by default.
SAFE_MODE=true
SCAN_MAX_CONCURRENCY=2
SCAN_REQUESTS_PER_SECOND=10
# Max endpoints the passive engine probes per scan.
SCAN_MAX_ENDPOINTS=50

# ---- Frontend ----
# Base URL the browser uses to reach the API.
VITE_API_BASE_URL=http://localhost:4000
